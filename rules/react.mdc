## Common Anti-Patterns to Avoid

### 1. Notifying Parent in Effect
```javascript
// 🔴 BAD
function Toggle({ onChange }) {
  const [isOn, setIsOn] = useState(false);
  
  useEffect(() => {
    onChange(isOn);
  }, [isOn, onChange]);
}

// ✅ GOOD
function Toggle({ onChange }) {
  const [isOn, setIsOn] = useState(false);
  
  function updateToggle(nextIsOn) {
    setIsOn(nextIsOn);
    onChange(nextIsOn);
  }
}
```

### 2. Passing Data to Parent
```javascript
// 🔴 BAD
function Child({ onFetched }) {
  const data = useSomeAPI();
  useEffect(() => {
    if (data) onFetched(data);
  }, [data, onFetched]);
}

// ✅ GOOD - fetch in parent, pass down
function Parent() {
  const data = useSomeAPI();
  return <Child data={data} />;
}
```

### 3. App Initialization in Effect
```javascript
// 🔴 BAD - runs twice in dev, not production-ready
function App() {
  useEffect(() => {
    loadDataFromLocalStorage();
    checkAuthToken();
  }, []);
}

// ✅ GOOD - top-level code
if (typeof window !== 'undefined') {
  loadDataFromLocalStorage();
  checkAuthToken();
}

function App() {
  // ...
}
```

### 4. POST Requests for User Actions
```javascript
// 🔴 BAD - buying in Effect
useEffect(() => {
  fetch('/api/buy', { method: 'POST' });
}, []);

// ✅ GOOD - buying on button click
function handleClick() {
  fetch('/api/buy', { method: 'POST' });
}
```

