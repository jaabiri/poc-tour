## Button Component Reference

### Token Definitions (in `index.css`)

```css
@theme {
  /* Button Spacing & Sizing - using --spacing-* namespace */
  --spacing-button-padding-x-lg: 24px;  /* → px-button-padding-x-lg */
  --spacing-button-padding-y-lg: 8px;   /* → py-button-padding-y-lg */
  --spacing-button-padding-x-sm: 16px;  /* → px-button-padding-x-sm */
  --spacing-button-padding-y-sm: 8px;   /* → py-button-padding-y-sm */
  --spacing-button-gap: 8px;            /* → gap-button-gap */
  --spacing-button-height-lg: 44px;     /* → h-button-height-lg */
  --spacing-button-height-sm: 36px;     /* → h-button-height-sm */
  --spacing-button-icon-lg: 24px;       /* → size-button-icon-lg */
  --spacing-button-icon-sm: 20px;       /* → size-button-icon-sm */
  
  /* Button Radius - using --radius-* namespace */
  --radius-button: 4px;                 /* → rounded-button */
}
```

### Component Usage

```jsx
// Base styles
'gap-button-gap',  // Auto-generated from --spacing-button-gap

const sizes = {
  sm: [
    'h-button-height-sm min-h-button-height-sm',
    'px-button-padding-x-sm py-button-padding-y-sm',
    'text-sm',           // Standard Tailwind (14px)
    'rounded-button',
    '[&_svg]:size-button-icon-sm',
  ],
  lg: [
    'h-button-height-lg min-h-button-height-lg',
    'px-button-padding-x-lg py-button-padding-y-lg',
    'text-base',         // Standard Tailwind (16px)
    'rounded-button',
    '[&_svg]:size-button-icon-lg',
  ],
  icon: [
    'size-button-height-lg min-h-button-height-lg min-w-button-height-lg',
    'p-0',
    'rounded-button',
    '[&_svg]:size-button-icon-lg',
  ],
};
```

### Color Variants

```jsx
// Primary Button
const primary = [
  'bg-brand-accent text-content-inverse',
  'border border-brand-accent',
  'hover:bg-accent-surface hover:text-brand-accent hover:border-brand-accent',
  'active:bg-brand-accent active:text-content-inverse',
  'disabled:bg-surface-disabled disabled:text-content-disabled',
  'focus-visible:ring-brand-accent',
];

// Secondary Button
const secondary = [
  'bg-surface-main text-accent-strong',
  'border border-accent-strong',
  'hover:bg-accent-surface hover:text-accent-strong',
  'active:bg-accent-strong active:text-content-inverse',
  'disabled:bg-surface-main disabled:text-content-disabled disabled:border-border-disabled',
];

// Tertiary Button
const tertiary = [
  'bg-transparent text-brand-accent',
  'underline decoration-current',
  'hover:text-accent-focus',
  'disabled:text-content-disabled',
];
```

