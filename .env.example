# Payload CMS secret — generate your own:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-with-a-strong-random-value

# SQLite (libSQL) database connection.
#   - Local dev: a local file at the repo root (`file:` URL).
#   - Vercel / production: a hosted libSQL (Turso) database — Vercel's filesystem
#     is read-only/ephemeral, so a `file:` DB would NOT persist. Create one with
#     the Turso CLI (`turso db create poc-tour`) and use its libsql:// URL here.
DATABASE_URI=file:./poc.db

# Turso auth token — REQUIRED when DATABASE_URI is a remote libsql:// URL.
# Generate with: turso db tokens create poc-tour. Leave empty for a local file DB.
DATABASE_AUTH_TOKEN=

# Vercel Blob storage token — REQUIRED on Vercel so media uploads persist (the
# serverless filesystem can't store them). Create a Blob store in the Vercel
# dashboard (Storage → Blob); Vercel injects this var automatically once linked.
# Leave empty locally to keep uploads on the local ./media disk.
BLOB_READ_WRITE_TOKEN=

# Live Preview (inline editing) — shared secret guarding the enable-preview
# endpoint (app/(frontend)/next/preview). Generate your own:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PREVIEW_SECRET=replace-with-a-strong-random-value

# Public base URL of the front-office, used to build Live Preview / "Aperçu"
# URLs. Leave empty for same-origin; set in deployed environments, e.g.
#   NEXT_PUBLIC_SERVER_URL=https://www.touraine.fr
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
