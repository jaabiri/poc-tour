# Payload CMS secret — generate your own:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=replace-with-a-strong-random-value

# SQLite (libSQL) database connection. file: URL is a local file at repo root.
DATABASE_URI=file:./poc.db

# Live Preview (inline editing) — shared secret guarding the enable-preview
# endpoint (app/(frontend)/next/preview). Generate your own:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PREVIEW_SECRET=replace-with-a-strong-random-value

# Public base URL of the front-office, used to build Live Preview / "Aperçu"
# URLs. Leave empty for same-origin; set in deployed environments, e.g.
#   NEXT_PUBLIC_SERVER_URL=https://www.touraine.fr
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
